{
  "name": "vscode-integrated-browser-mcp",
  "displayName": "Integrated Browser MCP Server",
  "description": "Exposes VS Code's Integrated Browser as an MCP server so external agents (Claude Code, etc.) can control it",
  "version": "0.4.1",
  "packageManager": "pnpm@10.30.3",
  "publisher": "Nagell",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "browser",
    "ai",
    "agent",
    "claude"
  ],
  "enabledApiProposals": [
    "browser"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "type": "module",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "integratedBrowserMcp.startServer",
        "title": "Integrated Browser MCP: Start Server"
      },
      {
        "command": "integratedBrowserMcp.stopServer",
        "title": "Integrated Browser MCP: Stop Server"
      },
      {
        "command": "integratedBrowserMcp.listTools",
        "title": "Integrated Browser MCP: List Available LM Tools (debug)"
      },
      {
        "command": "integratedBrowserMcp.enableCdp",
        "title": "Integrated Browser MCP: Enable CDP (dialog-free browser tools)"
      }
    ],
    "configuration": {
      "title": "Integrated Browser MCP",
      "properties": {
        "integratedBrowserMcp.port": {
          "type": "number",
          "default": 3100,
          "description": "Port the MCP server listens on"
        },
        "integratedBrowserMcp.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the MCP server automatically when VS Code opens"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run bundle",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.mjs",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "test": "vscode-test",
    "lint": "eslint src",
    "publish": "vsce publish --no-dependencies --allow-all-proposed-apis"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.112.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nagell/vscode-integrated-browser-mcp"
  },
  "license": "MIT"
}